{
  "name": "inaricode",
  "private": true,
  "workspaces": [
    "packages/cli",
    "packages/engine-native"
  ],
  "scripts": {
    "build:engine": "cargo build --manifest-path packages/engine/Cargo.toml --release",
    "build:engine:dev": "cargo build --manifest-path packages/engine/Cargo.toml",
    "build:native": "yarn workspace @inaricode/engine-native build",
    "build:cli": "yarn workspace @inaricode/cli build",
    "build": "yarn build:engine:dev && yarn build:cli",
    "test": "yarn workspace @inaricode/cli test && cargo test --manifest-path packages/engine/Cargo.toml"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
